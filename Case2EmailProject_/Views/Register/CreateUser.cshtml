@model Case2EmailProject_.Dtos.UserRegisterDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
	<!-- Required meta tags -->
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
	<title>Syndash - Bootstrap4 Admin Template</title>
	<!--favicon-->
	<link rel="icon" href="/vertical/assets/images/favicon-32x32.png" type="image/png" />
	<!-- loader-->
	<link href="/vertical/assets/css/pace.min.css" rel="stylesheet" />
	<script src="/vertical/assets/js/pace.min.js"></script>
	<!-- Bootstrap CSS -->
	<link rel="stylesheet" href="/vertical/assets/css/bootstrap.min.css" />
	<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&family=Roboto&display=swap" />
	<!-- Icons CSS -->
	<link rel="stylesheet" href="/vertical/assets/css/icons.css" />
	<!-- App CSS -->
	<link rel="stylesheet" href="/vertical/assets/css/app.css" />
</head>

<body class="bg-register">
	<!-- wrapper -->
	<div class="wrapper">
		<div class="section-authentication-register d-flex align-items-center justify-content-center min-vh-100">
			<div class="row w-100">
				<div class="col-12 col-lg-10 col-xl-8 mx-auto">
					<div class="card radius-15 overflow-hidden shadow-lg">
						<div class="row g-0">
							<div class="col-xl-6">
								<div class="card-body p-4">
									<div class="text-center mb-3">
										<img src="/vertical/assets/images/logo-icon.png" width="60" alt="">
										<h4 class="mt-3 font-weight-bold">Hesap Oluştur</h4>
									</div>

									<div class="d-grid gap-2 mb-3">
										<a class="btn btn-white shadow-sm" href="javascript:;">
											<span class="d-flex justify-content-center align-items-center">
												<img class="me-2" src="/vertical/assets/images/icons/search.svg" width="16" alt="Google">
												<span>Google ile Kayıt Ol</span>
											</span>
										</a>
										<a href="javascript:;" class="btn btn-facebook">
											<i class="bx bxl-facebook me-1"></i>Facebook ile Kayıt Ol
										</a>
									</div>

									<div class="login-separater text-center mb-3">
										<span>VEYA E-POSTA İLE</span>
										<hr>
									</div>

									<form method="post" class="row g-3">
										<div class="col-sm-6">
											<label for="inputFirstName" class="form-label">Ad</label>
											<input type="text" asp-for="Name" class="form-control" id="inputFirstName" placeholder="Ahmet" required>
										</div>
										<div class="col-sm-6">
											<label for="inputLastName" class="form-label">Soyad</label>
											<input type="text" asp-for="Surname" class="form-control" id="inputLastName" placeholder="Yılmaz" required>
										</div>
										<div class="col-12">
											<label for="inputEmailAddress" class="form-label">Email Adresi</label>
											<input type="email" asp-for="Email" class="form-control" id="inputEmailAddress" placeholder="ornek@mail.com" required>
										</div>
										<div class="col-12">
											<label for="inputUsername" class="form-label">Kullanıcı Adı</label>
											<input type="text" asp-for="Username" class="form-control" id="inputUsername" placeholder="kullanici123">
										</div>
										<div class="col-12">
											<label for="inputChoosePassword" class="form-label">Şifre</label>
											<div class="input-group" id="show_hide_password">
												<input type="password" asp-for="Password" required class="form-control border-end-0" id="inputChoosePassword" placeholder="Şifrenizi girin">
												<a href="javascript:;" class="input-group-text bg-transparent">
													<i class="bx bx-hide"></i>
												</a>
											</div>
										</div>
										<div class="text-danger" asp-validation-summary="ModelOnly"></div>

										<div class="col-12">
											<div class="form-check form-switch">
												<input class="form-check-input" type="checkbox" id="flexSwitchCheckChecked" required>
												<label class="form-check-label" for="flexSwitchCheckChecked">
													<a href="#" data-bs-toggle="modal" data-bs-target="#termsModal">Şartlar ve Koşulları</a> okudum ve kabul ediyorum.
												</label>
											</div>
										</div>
										<div class="col-12">
											<div class="d-grid">
												<button type="submit" class="btn btn-primary">
													<i class="bx bx-user me-1"></i>Kayıt Ol
												</button>
											</div>
										</div>
									</form>
								</div>
							</div>
							<div class="col-xl-6 bg-login-color d-flex align-items-center justify-content-center">
								<img src="/vertical/assets/images/login-images/register-frent-img.jpg" class="img-fluid" alt="...">
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>	<!-- Modal -->
	<div class="modal fade" id="termsModal" tabindex="-1" aria-labelledby="termsModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-lg modal-dialog-scrollable">
			<div class="modal-content">
				<div class="modal-header">
					<h1 class="modal-title fs-5" id="termsModalLabel">Şartlar ve Koşullar</h1>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<p>
						Bu web sitesine üye olarak aşağıda belirtilen şartları kabul etmiş sayılırsınız.
						Lütfen üyelik işlemini tamamlamadan önce dikkatlice okuyunuz.
					</p>

					<h6>1. Üyelik Koşulları</h6>
					<p>
						Kullanıcı, kayıt sırasında verdiği bilgilerin doğru ve güncel olduğunu kabul eder.
						Yanlış veya eksik bilgi verilmesi durumunda oluşabilecek sorunlardan kullanıcı sorumludur.
					</p>

					<h6>2. Gizlilik ve Kişisel Veriler</h6>
					<p>
						Kişisel bilgileriniz, 6698 sayılı Kişisel Verilerin Korunması Kanunu (KVKK)
						kapsamında korunmakta olup, üçüncü kişilerle izniniz olmadan paylaşılmaz.
					</p>

					<h6>3. Kullanıcı Yükümlülükleri</h6>
					<p>
						Kullanıcı, siteyi hukuka aykırı amaçlarla kullanmayacağını,
						diğer kullanıcıların haklarını ihlal etmeyeceğini kabul eder.
					</p>

					<h6>4. Hizmet Değişiklikleri</h6>
					<p>
						Site yönetimi, sunulan hizmetlerde önceden bildirimde bulunmaksızın
						değişiklik yapma hakkını saklı tutar.
					</p>

					<h6>5. Sorumluluğun Sınırlandırılması</h6>
					<p>
						Site kullanımı sırasında oluşabilecek doğrudan veya dolaylı zararlardan
						site yönetimi sorumlu tutulamaz.
					</p>

					<p class="mt-3">
						Üyelik işlemini tamamlayarak bu şartları okuduğunuzu, anladığınızı
						ve kabul ettiğinizi beyan etmiş olursunuz.
					</p>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="acceptTerms()">Okudum, anladım</button>
				</div>
			</div>
		</div>
	</div>
	<!-- JavaScript -->
	<!-- jQuery first, then Popper.js, then Bootstrap JS -->
	<script src="/vertical/assets/js/jquery.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
	<script>
		function acceptTerms() {
			document.getElementById("flexSwitchCheckChecked").checked = true;
		}
	</script>
	<!--Password show & hide js -->
	<script>
		$(document).ready(function () {
			$("#show_hide_password a").on('click', function (event) {
				event.preventDefault();
				if ($('#show_hide_password input').attr("type") == "text") {
					$('#show_hide_password input').attr('type', 'password');
					$('#show_hide_password i').addClass("bx-hide");
					$('#show_hide_password i').removeClass("bx-show");
				} else if ($('#show_hide_password input').attr("type") == "password") {
					$('#show_hide_password input').attr('type', 'text');
					$('#show_hide_password i').removeClass("bx-hide");
					$('#show_hide_password i').addClass("bx-show");
				}
			});
		});
	</script>
</body>

</html>